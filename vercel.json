{
  "version": 2,
  "functions": {
    "api/bilan.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/bilan", "destination": "/equilib-questionnaire.html" },
    { "source": "/", "destination": "/equilib-landing.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache" }
      ]
    }
  ]
}
